{
  "name": "routelens",
  "displayName": "RouteLens",
  "description": "Visualize, navegue e documente rotas de APIs diretamente no VS Code.",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:routelens.routes"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "routelens.routes",
          "name": "Routes"
        }
      ]
    },
    "commands": [
      {
        "command": "routelens.refreshRoutes",
        "title": "RouteLens: Refresh Routes"
      },
      {
        "command": "routelens.openRoute",
        "title": "RouteLens: Open Route"
      },
      {
        "command": "routelens.copyRoute",
        "title": "RouteLens: Copy Route"
      },
      {
        "command": "routelens.copyMethodAndRoute",
        "title": "RouteLens: Copy Method + Route"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "routelens.copyRoute",
          "when": "view == routelens.routes && viewItem == route",
          "group": "inline"
        },
        {
          "command": "routelens.copyMethodAndRoute",
          "when": "view == routelens.routes && viewItem == route",
          "group": "inline"
        },
        {
          "command": "routelens.openRoute",
          "when": "view == routelens.routes && viewItem == route",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "routelens.refreshRoutes",
          "when": "view == routelens.routes",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
